# ═══════════════════════════════════════════════════════
# AutoSig — Environment Variable Reference
# ═══════════════════════════════════════════════════════
# Copy this file to .env and fill in your own values.
# NEVER commit the real .env file to source control.
# ═══════════════════════════════════════════════════════

# ── REQUIRED ─────────────────────────────────────────────────────────────────

# Your Solana treasury keypair, Base64-encoded.
# Generate one: dotnet run --project src/AutoSig.Console -- --generate-key
AUTOSIG_SOLANA_PRIVATE_KEY=YOUR_BASE64_PRIVATE_KEY_HERE

# Your OpenRouter API key (free tier works: https://openrouter.ai)
AUTOSIG_OPENROUTER_KEY=sk-or-v1-YOUR_KEY_HERE

# ── LLM MODELS (per-agent) ────────────────────────────────────────────────────
# Each agent uses its OWN independently-configured LLM.
# The Strategist needs deep reasoning; the Risk Manager needs fast evaluation.
#
# IMPORTANT: Use model slugs from https://openrouter.ai/models
# If a model returns 404, it is not available on your account tier.
# The app will HALT that cycle and not execute any transaction if the LLM fails.
#
# Confirmed working free models (universally available on OpenRouter free tier):
#   meta-llama/llama-3.3-70b-instruct:free   ← Best free reasoning model
#   meta-llama/llama-3.1-8b-instruct:free    ← Fastest free model
#   google/gemma-2-9b-it:free                ← Alternative
#   mistralai/mistral-7b-instruct:free       ← Alternative
#
# DeepSeek models (may be unavailable depending on your account/region):
#   deepseek/deepseek-chat:free
#   deepseek/deepseek-r1:free

# Strategist Agent — crafts the trade proposal (reasoning-heavy)
AUTOSIG_STRATEGIST_MODEL=meta-llama/llama-3.3-70b-instruct:free

# Risk Manager Agent — evaluates proposals for semantic risk (speed-focused)
AUTOSIG_RISK_MODEL=meta-llama/llama-3.1-8b-instruct:free

# ── OUTPUT VERBOSITY ──────────────────────────────────────────────────────────
# Controls how much log output appears in the terminal.
# Set AUTOSIG_OUTPUT_LEVEL to one of:
#
#   brief    — Only the 4 agent summary panels. No step-by-step logs.
#   normal   — Key phase transitions per agent (recommended for demos).
#   verbose  — Every step from every agent, minus LLM internals.
#   debug    — Everything: LLM attempt counts, raw JSON, exception traces.
#
AUTOSIG_OUTPUT_LEVEL=normal

# ── TRADING POLICY ────────────────────────────────────────────────────────────
# All lamport values: 1 SOL = 1,000,000,000 lamports

# Max lamports allowed in a single transaction (default: 0.5 SOL)
AUTOSIG_MAX_TX_LAMPORTS=500000000

# Minimum lamports to always keep in the treasury (default: 0.05 SOL)
AUTOSIG_MIN_RESERVE_LAMPORTS=50000000

# Max trades per hour (velocity limiter, default: 10)
AUTOSIG_MAX_TRADES_PER_HOUR=10

# Minimum seconds between any two trades (cooldown, default: 15)
AUTOSIG_TRADE_COOLDOWN_SECONDS=15

# Max daily drawdown as a fraction (default: 0.05 = 5%)
AUTOSIG_MAX_DAILY_DRAWDOWN=0.05

# ── SOLANA CLUSTER ────────────────────────────────────────────────────────────
# RPC endpoint — "devnet" for testing, or a full URL for a private node.
# Options: devnet | mainnet-beta | https://your-custom-rpc.com
AUTOSIG_SOLANA_CLUSTER=devnet
